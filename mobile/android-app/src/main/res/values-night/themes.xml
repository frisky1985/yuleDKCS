<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Material 3 Dark Theme -->
    <style name="Theme.DigitalKey" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/primary_light</item>
        <item name="colorPrimaryDark">@color/primary</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="colorPrimaryContainer">@color/primary_dark</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/secondary_light</item>
        <item name="colorOnSecondary">#000000</item>
        <item name="colorSecondaryContainer">@color/secondary_dark</item>

        <!-- Tertiary / Accent -->
        <item name="colorTertiary">@color/accent_light</item>
        <item name="colorOnTertiary">#000000</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary_dark</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary_dark</item>

        <!-- Error -->
        <item name="colorError">#EF5350</item>
        <item name="colorOnError">#000000</item>

        <!-- Outline -->
        <item name="colorOutline">@color/divider_dark</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>
    </style>
</resources>
